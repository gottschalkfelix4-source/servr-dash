# Required: Secret for JWT authentication (use a long random string)
AUTH_SECRET=change-me-to-a-random-secret-string

# Optional: Timezone
TZ=Europe/Berlin

# Optional: Plex (can also be configured via Settings UI)
# PLEX_URL=http://localhost:32400
# PLEX_TOKEN=your_plex_token

# Optional: Radarr (can also be configured via Settings UI)
# RADARR_URL=http://localhost:7878
# RADARR_API_KEY=your_radarr_api_key

# Optional: Sonarr (can also be configured via Settings UI)
# SONARR_URL=http://localhost:8989
# SONARR_API_KEY=your_sonarr_api_key
